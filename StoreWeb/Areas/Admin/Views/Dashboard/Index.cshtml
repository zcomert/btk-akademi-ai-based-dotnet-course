@model IEnumerable<Product>

@{
    var productCount = (int?)ViewData["ProductCount"] ?? 0;
    var totalInventoryValue = (decimal?)ViewData["TotalInventoryValue"] ?? 0m;
}

<section class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-semibold">Admin Dashboard</h1>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-primary">Manage Products</a>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        <article class="card card-body">
            <p class="text-sm text-slate-500">Total Products</p>
            <p class="text-3xl font-bold">@productCount</p>
        </article>
        <article class="card card-body">
            <p class="text-sm text-slate-500">Total Inventory Value</p>
            <p class="text-3xl font-bold">@totalInventoryValue.ToString("C")</p>
        </article>
    </div>

    <section class="card card-body space-y-3">
        <h2 class="text-lg font-semibold">Recently Added Products</h2>
        @if (!Model.Any())
        {
            <p class="muted">No products available yet.</p>
        }
        else
        {
            <ul class="space-y-2">
                @foreach (var product in Model)
                {
                    <li class="flex items-center justify-between border-b border-slate-200 pb-2">
                        <div>
                            <p class="font-medium">@product.ProductName</p>
                            <p class="text-sm text-slate-500">Id: @product.ProductId</p>
                        </div>
                        <div class="text-right">
                            <p class="font-semibold">@product.Price.ToString("C")</p>
                            <a asp-area="Admin"
                               asp-controller="Product"
                               asp-action="Edit"
                               asp-route-id="@product.ProductId"
                               class="text-sm text-brand-700 hover:underline">
                                Edit
                            </a>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>
</section>
