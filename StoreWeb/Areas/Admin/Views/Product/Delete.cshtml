@model Product

<section class="space-y-4">
    <h1 class="text-2xl font-semibold text-red-700">Delete Product</h1>

    <div class="card card-body space-y-2">
        <p>You are about to delete this product.</p>
        <p><strong>Id:</strong> @Model.ProductId</p>
        <p><strong>Name:</strong> @Model.ProductName</p>
        <p><strong>Price:</strong> @Model.Price.ToString("C")</p>
    </div>

    <form asp-area="Admin" asp-controller="Product" asp-action="Delete" method="post" class="flex gap-2">
        <input type="hidden" asp-for="ProductId" />
        <button type="submit" class="btn btn-primary">Confirm Delete</button>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</section>
