@model StoreWeb.ViewModels.Admin.UserManagementEditViewModel

<section class="space-y-4">
    <h1 class="text-2xl font-semibold">Edit User</h1>

    <div class="card card-body">
        <form asp-area="Admin" asp-controller="UserManagement" asp-action="Edit" method="post" class="space-y-4">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            <div>
                <label asp-for="FullName" class="mb-1 block text-sm font-medium"></label>
                <input asp-for="FullName" class="w-full rounded border border-slate-300 px-3 py-2" />
                <span asp-validation-for="FullName" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Email" class="mb-1 block text-sm font-medium"></label>
                <input asp-for="Email" class="w-full rounded border border-slate-300 px-3 py-2" />
                <span asp-validation-for="Email" class="text-sm text-red-600"></span>
            </div>

            <div class="grid gap-3 md:grid-cols-2">
                <div>
                    <label asp-for="NewPassword" class="mb-1 block text-sm font-medium"></label>
                    <input asp-for="NewPassword" class="w-full rounded border border-slate-300 px-3 py-2" />
                    <span asp-validation-for="NewPassword" class="text-sm text-red-600"></span>
                    <p class="mt-1 text-xs text-slate-500">Leave empty to keep current password.</p>
                </div>
                <div>
                    <label asp-for="ConfirmNewPassword" class="mb-1 block text-sm font-medium"></label>
                    <input asp-for="ConfirmNewPassword" class="w-full rounded border border-slate-300 px-3 py-2" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-sm text-red-600"></span>
                </div>
            </div>

            <div>
                <label class="mb-2 block text-sm font-medium">Roles</label>
                <div class="flex flex-wrap gap-3">
                    @foreach (var role in Model.RoleOptions)
                    {
                        <label class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                            <input type="checkbox" name="SelectedRoles" value="@role.Value" checked="@role.Selected" class="h-4 w-4" />
                            <span>@role.Text</span>
                        </label>
                    }
                </div>
                <span asp-validation-for="SelectedRoles" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                    <input asp-for="IsLockedOut" class="h-4 w-4" />
                    <span>Lock this account</span>
                </label>
            </div>

            <div class="flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
