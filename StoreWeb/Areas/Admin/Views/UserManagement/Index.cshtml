@model StoreWeb.ViewModels.Admin.UserManagementIndexViewModel

<section class="space-y-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-semibold">User Management</h1>
        <a asp-area="Admin" asp-controller="UserManagement" asp-action="Create" class="btn btn-primary">Create User</a>
    </div>

    @if (TempData["AdminUserMessage"] is string message && !string.IsNullOrWhiteSpace(message))
    {
        <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
            @message
        </div>
    }

    <div class="card card-body">
        <form asp-area="Admin" asp-controller="UserManagement" asp-action="Index" method="get" class="grid gap-3 md:grid-cols-3">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Search</label>
                <input asp-for="SearchTerm" class="w-full rounded border border-slate-300 px-3 py-2" placeholder="Name or email" />
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Role</label>
                <select asp-for="RoleFilter" asp-items="Model.RoleOptions" class="w-full rounded border border-slate-300 px-3 py-2">
                    <option value="">All Roles</option>
                </select>
            </div>
            <div class="flex items-end gap-2">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index" class="btn btn-secondary">Clear</a>
            </div>
        </form>
    </div>

    @if (!Model.Users.Any())
    {
        <div class="card card-body">
            <p class="text-sm text-slate-500">No users found for the current filters.</p>
        </div>
    }
    else
    {
        <div class="card card-body overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead>
                    <tr class="text-left">
                        <th class="py-2">Full Name</th>
                        <th class="py-2">Email</th>
                        <th class="py-2">Roles</th>
                        <th class="py-2">Status</th>
                        <th class="py-2">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr class="border-t border-slate-200">
                            <td class="py-2">@user.FullName</td>
                            <td class="py-2">@user.Email</td>
                            <td class="py-2">@string.Join(", ", user.Roles)</td>
                            <td class="py-2">
                                @if (user.IsLockedOut)
                                {
                                    <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-800">Locked</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">Active</span>
                                }
                            </td>
                            <td class="py-2">
                                <div class="flex flex-wrap gap-2">
                                    <a asp-area="Admin" asp-controller="UserManagement" asp-action="Details" asp-route-id="@user.Id" class="btn btn-secondary">Details</a>
                                    <a asp-area="Admin" asp-controller="UserManagement" asp-action="Edit" asp-route-id="@user.Id" class="btn btn-secondary">Edit</a>
                                    <a asp-area="Admin" asp-controller="UserManagement" asp-action="Delete" asp-route-id="@user.Id" class="btn btn-secondary">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
