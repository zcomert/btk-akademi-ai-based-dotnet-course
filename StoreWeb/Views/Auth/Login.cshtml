@model LoginViewModel
@{
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<section class="auth-shell stack reveal" data-reveal>
    <header class="page-hero" style="padding-bottom:.5rem;">
        <p class="page-label">Hesap</p>
        <h1 class="page-title">Giris Yap</h1>
        <p class="page-copy">Hesabiniza giris yaparak yonetim ve ozel sayfalara erisebilirsiniz.</p>
    </header>

    @if (TempData["AuthMessage"] is string authMessage && !string.IsNullOrWhiteSpace(authMessage))
    {
        <div class="notice">@authMessage</div>
    }

    <div class="auth-card">
        <form asp-action="Login" asp-controller="Auth" asp-route-returnUrl="@returnUrl" method="post" class="stack">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="input-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="input-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <label style="display:inline-flex; align-items:center; gap:.45rem; font-size:.9rem; color:#45464d;">
                <input asp-for="RememberMe" class="h-4 w-4" />
                <span>Beni hatirla</span>
            </label>

            <button type="submit" class="btn btn-primary" style="width:100%;">Giris Yap</button>
        </form>

        <p class="muted" style="margin:.9rem 0 0;">
            Hesabin yok mu?
            <a asp-controller="Auth" asp-action="Register" asp-route-returnUrl="@returnUrl" style="color:#131b2e; font-weight:700; text-decoration:none;">Kayit Ol</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

