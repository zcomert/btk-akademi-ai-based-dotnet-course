@model RegisterViewModel
@{
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<section class="mx-auto max-w-xl space-y-6">
    <header class="space-y-2">
        <h1 class="font-heading text-3xl font-bold text-slate-900">Kayit Ol</h1>
        <p class="text-slate-600">Yeni bir hesap olusturarak uygulamayi kullanmaya baslayabilirsiniz.</p>
    </header>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
        <form asp-action="Register" asp-controller="Auth" asp-route-returnUrl="@returnUrl" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            <div class="space-y-1">
                <label asp-for="FullName" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="FullName" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                <span asp-validation-for="FullName" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Email" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="Email" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                <span asp-validation-for="Email" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Password" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="Password" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                <span asp-validation-for="Password" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="ConfirmPassword" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                <span asp-validation-for="ConfirmPassword" class="text-sm text-red-600"></span>
            </div>

            <button type="submit" class="inline-flex w-full items-center justify-center rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-700">
                Kayit Ol
            </button>
        </form>

        <p class="mt-4 text-sm text-slate-600">
            Zaten hesabin var mi?
            <a asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@returnUrl" class="font-semibold text-brand-600 hover:text-brand-700">
                Giris Yap
            </a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
