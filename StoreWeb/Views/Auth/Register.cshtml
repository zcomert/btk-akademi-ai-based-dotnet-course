@model RegisterViewModel
@{
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<section class="auth-shell stack reveal" data-reveal>
    <header class="page-hero" style="padding-bottom:.5rem;">
        <p class="page-label">Hesap</p>
        <h1 class="page-title">Kayit Ol</h1>
        <p class="page-copy">Yeni hesap olusturun ve uygulamayi kullanmaya baslayin.</p>
    </header>

    <div class="auth-card">
        <form asp-action="Register" asp-controller="Auth" asp-route-returnUrl="@returnUrl" method="post" class="stack">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="input-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="input-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="input-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="input-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;">Kayit Ol</button>
        </form>

        <p class="muted" style="margin:.9rem 0 0;">
            Zaten hesabin var mi?
            <a asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@returnUrl" style="color:#131b2e; font-weight:700; text-decoration:none;">Giris Yap</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
