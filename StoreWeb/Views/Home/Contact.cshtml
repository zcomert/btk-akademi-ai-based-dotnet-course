@{
    ViewData["Title"] = "Iletisim";
}

<section class="page-hero reveal" data-reveal>
    <p class="page-label">Iletisim</p>
    <h1 class="page-title">Bize Ulasin</h1>
    <p class="page-copy">Sorularinizi iletin, ekibimiz en kisa surede donus yapsin.</p>
</section>

<section class="stack" style="grid-template-columns:1fr;">
    <div style="display:grid; gap:1rem; grid-template-columns:repeat(auto-fit, minmax(280px,1fr));">
        <article class="card card-body reveal" data-reveal>
            <p class="page-label" style="margin-bottom:.4rem;">Iletisim Merkezi</p>
            <p class="muted">Telefon: +90 362 000 00 00</p>

            <form method="post" asp-action="Contact" class="stack" novalidate data-contact-form style="margin-top:.8rem;">
                <div class="field">
                    <label class="form-label" for="name">Ad Soyad</label>
                    <input class="input-control" type="text" id="name" name="name" autocomplete="name" required data-validate />
                    <p class="field-message" data-field-message></p>
                </div>

                <div class="field">
                    <label class="form-label" for="email">E-posta</label>
                    <input class="input-control" type="email" id="email" name="email" autocomplete="email" required data-validate />
                    <p class="field-message" data-field-message></p>
                </div>

                <div class="field">
                    <label class="form-label" for="message">Mesaj</label>
                    <textarea class="input-control" id="message" name="message" rows="5" required data-validate></textarea>
                    <p class="field-message" data-field-message></p>
                </div>

                <div style="display:flex; gap:.7rem; flex-wrap:wrap;">
                    <button class="btn btn-primary" type="submit">Gonder</button>
                    <a class="btn btn-secondary" href="/">Ana Sayfa</a>
                </div>
                <p class="form-status" aria-live="polite" data-form-status></p>
            </form>
        </article>

        <article class="card card-body reveal" data-reveal>
            <h2 class="card-title">Konum</h2>
            <p class="muted" style="margin-top:.4rem;">Samsun merkezli ekibimizin konumunu harita uzerinden inceleyebilirsiniz.</p>
            <div style="margin-top:1rem; overflow:hidden; border-radius:.65rem; border:1px solid rgba(69,70,77,.2);">
                <iframe
                    title="Samsun Konumu"
                    src="https://www.google.com/maps?q=Samsun&output=embed"
                    class="h-[420px] w-full"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    allowfullscreen>
                </iframe>
            </div>
        </article>
    </div>
</section>
