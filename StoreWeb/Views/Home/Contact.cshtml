@{
    ViewData["Title"] = "Iletisim";
}

<section class="section grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <article class="card reveal" data-reveal>
        <div class="card-body md:p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-700">Iletisim Merkezi</p>
            <h1 class="mt-2 font-heading text-3xl font-extrabold tracking-tight text-slate-900">Bize ulasin</h1>
            <p class="mt-3 text-slate-600">Sorularinizi iletebilir, geri bildirim birakabilir ve ekibimizle hizli sekilde baglanti kurabilirsiniz.</p>

            <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-sm font-semibold text-slate-800">Telefon</p>
                <p class="mt-1 text-lg font-bold text-slate-900">+90 362 000 00 00</p>
            </div>

            <form method="post" asp-action="Contact" class="mt-6 space-y-4" novalidate data-contact-form>
                <div class="field">
                    <label class="form-label" for="name">Ad Soyad</label>
                    <input class="input-control" type="text" id="name" name="name" autocomplete="name" required data-validate />
                    <p class="field-message" data-field-message></p>
                </div>

                <div class="field">
                    <label class="form-label" for="email">E-posta</label>
                    <input class="input-control" type="email" id="email" name="email" autocomplete="email" required data-validate />
                    <p class="field-message" data-field-message></p>
                </div>

                <div class="field">
                    <label class="form-label" for="message">Mesaj</label>
                    <textarea class="input-control" id="message" name="message" rows="5" required data-validate></textarea>
                    <p class="field-message" data-field-message></p>
                </div>

                <div class="flex flex-wrap gap-3">
                    <button class="btn btn-primary" type="submit">
                        <iconify-icon icon="heroicons:paper-airplane-20-solid" width="18" height="18"></iconify-icon>
                        Gonder
                    </button>
                    <a class="btn btn-secondary" href="/">Ana Sayfa</a>
                </div>
                <p class="form-status" aria-live="polite" data-form-status></p>
            </form>
        </div>
    </article>

    <article class="card reveal" data-reveal>
        <div class="card-body md:p-8">
            <h2 class="card-title">Konum</h2>
            <p class="mt-1 muted">Samsun merkezli ekibimizin konumunu harita uzerinden inceleyebilirsiniz.</p>
            <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
                <iframe
                    title="Samsun Konumu"
                    src="https://www.google.com/maps?q=Samsun&output=embed"
                    class="h-[420px] w-full"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    allowfullscreen>
                </iframe>
            </div>
        </div>
    </article>
</section>
