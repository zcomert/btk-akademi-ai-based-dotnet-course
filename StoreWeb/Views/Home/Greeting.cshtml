@model StoreWeb.Models.GreetingModel
@{
    ViewData["Title"] = "Selamlama";
}

<section class="page-hero reveal" data-reveal>
    <p class="page-label">Karsilama</p>
    <h1 class="page-title">Merhaba @Model?.Name</h1>
    <p class="page-copy">Bu sayfa @Model?.Date.ToString("dd.MM.yyyy HH:mm") tarihinde olusturuldu.</p>
</section>

<section class="stack">
    <article class="card card-body reveal" data-reveal>
        <h2 class="card-title">Sehir Listesi</h2>
        <p class="muted" style="margin-top:.4rem;">Asagidaki sehirler modelden dinamik olarak gelmektedir.</p>

        <ul style="margin-top:1rem; display:grid; gap:.7rem; grid-template-columns:repeat(auto-fit, minmax(180px,1fr)); list-style:none; padding:0;">
            @foreach (var city in Model?.Cities ?? new List<City>())
            {
                <li class="card" style="padding:.75rem;">
                    <p style="margin:0; font-weight:700;">@city.Name</p>
                    <p class="muted" style="margin:.25rem 0 0;">Plaka: @city.Number</p>
                </li>
            }
        </ul>

        <div style="display:flex; gap:.7rem; flex-wrap:wrap; margin-top:1rem;">
            <a class="btn btn-secondary" href="/">Ana Sayfa</a>
            <a class="btn btn-primary" href="/home/contact">Iletisim</a>
        </div>
    </article>
</section>
