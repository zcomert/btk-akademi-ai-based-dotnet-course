@model StoreWeb.Models.GreetingModel
@{
    ViewData["Title"] = "Selamlama";
}

<section class="section reveal" data-reveal>
    <div class="card overflow-hidden">
        <div class="card-body md:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-700">Karsilama</p>
            <h1 class="mt-2 font-heading text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">
                Merhaba @Model?.Name
            </h1>
            <p class="mt-3 text-slate-600">
                Bu sayfa <strong>@Model?.Date.ToString("dd.MM.yyyy HH:mm")</strong> tarihinde olusturuldu.
            </p>
        </div>
    </div>
</section>

<section class="section reveal" data-reveal>
    <div class="card">
        <div class="card-body">
            <h2 class="card-title">Sehir Listesi</h2>
            <p class="mt-1 muted">Asagidaki sehirler modelden dinamik olarak gelmektedir.</p>

            <ul class="mt-5 grid gap-3 sm:grid-cols-2">
                @foreach (var city in Model?.Cities ?? new List<City>())
                {
                    <li class="rounded-xl border border-slate-200 bg-white p-3">
                        <p class="font-semibold text-slate-800">@city.Name</p>
                        <p class="text-sm text-slate-500">Plaka: @city.Number</p>
                    </li>
                }
            </ul>

            <div class="mt-6 flex flex-wrap gap-3">
                <a class="btn btn-secondary" href="/">Ana Sayfa</a>
                <a class="btn btn-primary" href="/home/contact">Iletisim</a>
            </div>
        </div>
    </div>
</section>
