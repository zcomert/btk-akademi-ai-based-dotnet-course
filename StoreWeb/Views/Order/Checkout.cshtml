@model CheckoutViewModel

@{
    ViewData["Title"] = "Siparisi Tamamla";
}

<section class="page-hero reveal" data-reveal>
    <p class="page-label">Son Adim</p>
    <h1 class="page-title">Teslimat Bilgileri</h1>
    <p class="page-copy">Siparisi tamamlamak icin teslimat detaylarini girin.</p>
</section>

<section class="card card-body reveal" data-reveal style="max-width:640px;">
    <form asp-controller="Order" asp-action="PlaceOrder" method="post" class="stack">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="muted" style="color:#b91c1c;"></div>

        <div>
            <label asp-for="FullName" class="form-label"></label>
            <input asp-for="FullName" class="mock-input" placeholder="Orn: Ahmet Yilmaz" />
            <span asp-validation-for="FullName" style="color:#b91c1c;font-size:.85rem;"></span>
        </div>

        <div>
            <label asp-for="Address" class="form-label"></label>
            <textarea asp-for="Address" class="mock-input" rows="4" style="resize:vertical;" placeholder="Mahalle, sokak, bina no, daire..."></textarea>
            <span asp-validation-for="Address" style="color:#b91c1c;font-size:.85rem;"></span>
        </div>

        <div style="display:flex; gap:.7rem; flex-wrap:wrap;">
            <button type="submit" class="btn btn-primary">Siparisi Onayla</button>
            <a asp-controller="Cart" asp-action="Index" class="btn btn-secondary">Sepete Don</a>
        </div>
    </form>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
