@model Order

@{
    ViewData["Title"] = "Siparis Onayi";
    var total = Model.OrderItems.Sum(item => item.Price * item.Quantity);
}

<section class="page-hero reveal" data-reveal>
    <p class="page-label">Tesekkurler</p>
    <h1 class="page-title">Siparisiniz Alindi</h1>
    <p class="page-copy">Siparisiniz basariyla olusturuldu. Kisa sure icinde kargoya verilecektir.</p>
</section>

<section class="card card-body reveal stack" data-reveal>
    <div class="stack" style="gap:.35rem;">
        <p><strong>Siparis No:</strong> #@Model.OrderId</p>
        <p><strong>Tarih:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Teslimat Adresi:</strong> @Model.Address</p>
    </div>

    <h2 class="card-title">Siparis Ozeti</h2>

    @foreach (var item in Model.OrderItems)
    {
        <div style="display:flex; justify-content:space-between; gap:.8rem; flex-wrap:wrap; padding:.45rem 0; border-top:1px solid rgba(69,70,77,.16);">
            <span>@item.ProductName <span class="muted">x @item.Quantity</span></span>
            <strong>@((item.Price * item.Quantity).ToString("C"))</strong>
        </div>
    }

    <div style="display:flex; justify-content:space-between; font-size:1.08rem; font-weight:700; padding-top:.2rem;">
        <span>Toplam</span>
        <span>@total.ToString("C")</span>
    </div>

    <a asp-controller="Product" asp-action="Index" class="btn btn-primary" style="width:max-content;">
        Alisverise Devam Et
    </a>
</section>
